                            if len(df_col) < 5: continue
                            n_bl = max(2, int(len(df_col)*0.3))
                            s_bl = _calcular_sem_mdc(df_col.nsmallest(n_bl,'DATA')[col].values)
                            if not s_bl: continue
                            mdc_b = s_bl['MDC_95']
                            for grupo in sorted(df_col['Drag_Quartil'].unique()):
                                df_g = df_col[df_col['Drag_Quartil']==grupo].sort_values('DATA')
                                if len(df_g) < 3: continue
                                mud_g = df_g[col].iloc[-1] - df_g[col].iloc[0]
                                mult = abs(mud_g)/mdc_b if mdc_b > 0 else 0
                                x_g = (df_g['DATA']-df_g['DATA'].min()).dt.days.values
                                y_g = df_g[col].values
                                sl_g, _, _, pv_g, _ = (linregress(x_g, y_g)
                                                        if len(np.unique(x_g))>=2 else (0,0,0,1,0))
                                tend_rows.append({
                                    'Potência (W)':pw_d,'Grupo':grupo,'N':len(df_g),
                                    'MDC-95 ref':f"{mdc_b:.1f}",
                                    'Mudança início→fim':f"{mud_g:+.1f} {unid_d}",
                                    'Múltiplos MDC':f"{mult:.2f}x",
                                    'Slope (dia)':f"{sl_g:.4f}",'p-value':f"{pv_g:.4f}",
                                    'Sig.':'✓' if pv_g<0.05 else '✗',
                                    'Veredicto':('✓ MUDANÇA REAL' if mult>=1
                                                 else '⚠️ Possível mudança' if mult>=0.5
                                                 else '✗ Dentro do erro'),
                                })
                        if tend_rows:
                            st.dataframe(pd.DataFrame(tend_rows), width="stretch", hide_index=True)

                    with st.expander("📚 Explicação SEM/MDC"):
                        st.markdown("""
**SEM** = SD × √(1 − ICC), com ICC = 0.9
**MDC₉₅** = SEM × 1.96 × √2 — mudança mínima REAL com 95% confiança

| CV% | Confiabilidade |
|---|---|
| < 10% | ✓ Boa |
| 10–15% | 🟡 Moderada |
| > 15% | ⚠️ Alta variabilidade |
                        """)

            # ════════════════════════════════════════════════════════════
            # 8. Treino Antes
            # ════════════════════════════════════════════════════════════
            if treino_col and (hr_cols or o2_cols):
                st.subheader(f"🏋️ Treino Antes — impacto no HR/O2 ({aba})")
                df_ta = df_plot.copy()
                df_ta[treino_col] = (df_ta[treino_col].astype(str).str.strip().str.lower()
                                     .replace({'nan':None,'none':None,'':None,'n/a':None}))
                cats_raw = sorted(df_ta[treino_col].dropna().unique().tolist())
                st.caption(f"Categorias: {', '.join(cats_raw) if cats_raw else 'nenhuma'}")

                for col in hr_cols + o2_cols:
                    if col not in df_ta.columns: continue
                    pw = _extrair_pot(col); tipo = 'HR' if col in hr_cols else 'SmO2'
                    unid = 'bpm' if tipo == 'HR' else '%'
                    df_col = df_ta[[treino_col, col]].copy()
                    df_col['_tem'] = df_col[treino_col].notna()
                    df_col = df_col.dropna(subset=[col])
                    if len(df_col) < 4: continue
                    st.markdown(f"**{tipo} {pw}W**")
                    rows_ta = []
                    for lbl, vals in [('Com treino antes', df_col[df_col['_tem']][col].values),
                                      ('Sem treino antes', df_col[~df_col['_tem']][col].values)]:
                        if len(vals) == 0: continue
                        rows_ta.append({'Grupo':lbl,'N':len(vals),
                            f'Media {tipo} ({unid})':f"{np.mean(vals):.1f}",
                            'Mediana':f"{np.median(vals):.1f}",
                            'STD':f"{np.std(vals,ddof=1):.1f}" if len(vals)>1 else '—'})
                    for cat in cats_raw:
                        vals_c = df_col[df_col[treino_col]==cat][col].values
                        if len(vals_c)==0: continue
                        rows_ta.append({'Grupo':cat.capitalize(),'N':len(vals_c),
                            f'Media {tipo} ({unid})':f"{np.mean(vals_c):.1f}",
                            'Mediana':f"{np.median(vals_c):.1f}",
                            'STD':f"{np.std(vals_c,ddof=1):.1f}" if len(vals_c)>1 else '—'})
                    if rows_ta:
                        st.dataframe(pd.DataFrame(rows_ta), width="stretch", hide_index=True)
                    comp_rows = []
                    com_v = df_col[df_col['_tem']][col].values
                    sem_v = df_col[~df_col['_tem']][col].values
                    grupos_comp = []
                    if len(com_v) >= 3 and len(sem_v) >= 3:
                        grupos_comp.append(('Com treino', com_v, 'Sem treino', sem_v))
                    for c1c, c2c in combinations(cats_raw, 2):
                        v1 = df_col[df_col[treino_col]==c1c][col].values
                        v2 = df_col[df_col[treino_col]==c2c][col].values
                        if len(v1)>=3 and len(v2)>=3:
                            grupos_comp.append((c1c.capitalize(),v1,c2c.capitalize(),v2))
                    for g1_n, v1, g2_n, v2 in grupos_comp:
                        stat, pval = scipy_stats.mannwhitneyu(v1, v2, alternative='two-sided')
                        delta = np.mean(v1) - np.mean(v2)
                        s_mdc = _calcular_sem_mdc(np.concatenate([v1, v2]))
                        mdc_v = s_mdc['MDC_95'] if s_mdc else None
                        comp_rows.append({
                            'Comparacao':f"{g1_n} vs {g2_n}",
                            f'Delta {tipo} ({unid})':f"{delta:+.1f}",
                            'p-value':f"{pval:.4f}",'Sig.':'SIG' if pval<0.05 else 'ns',
                            'MDC-95':f"{mdc_v:.2f}" if mdc_v else '—',
                            'Diferenca real':('REAL' if mdc_v and abs(delta)>=mdc_v
                                              else 'Próximo' if mdc_v and abs(delta)>=mdc_v*0.5
                                              else 'Dentro do erro'),
                        })
                    if comp_rows:
                        st.markdown("*Testes Mann-Whitney U:*")
                        st.dataframe(pd.DataFrame(comp_rows), width="stretch", hide_index=True)
