                        if pw in res_tend:
                            r = res_tend[pw]
                            y_lin = r['intercept'] + r['slope'] * r['dias']
                            sig = '✓' if r['p_value'] < 0.05 else '—'
                            fig_t.add_trace(go.Scatter(
                                x=df_t['DATA'], y=y_lin,
                                mode='lines', name=f'{pw}W {r["classificacao"]} ({sig})',
                                line=dict(color=cor, width=1.5, dash='dash'),
                                hovertemplate=f'Tendência {pw}W: <b>%{{y:.1f}} {unid_t}</b><extra></extra>',
                            ))

                title_agrup = f" — agrupado por {agrup_lbl}" if agrup_code else f" — sessão a sessão | roll={roll}"
                fig_t.update_layout(
                    **PLOTLY_WHITE,
                    title=f'{aba} — {tipo_t} evolução temporal{title_agrup}',
                    height=450,
                    hovermode='x unified',
                    xaxis=dict(title='Data', showgrid=True, gridcolor='#eeeeee'),
                    yaxis=dict(title=f'{tipo_t} ({unid_t})', showgrid=True, gridcolor='#eeeeee'),
                    legend=dict(orientation='h', y=1.02, x=0),
                    barmode='group',
                )
