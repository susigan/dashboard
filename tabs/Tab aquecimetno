                          for _, row in df_plot[['DATA',c]].dropna().iterrows()]
                if not rows_t:
                    st.info(f"Sem dados de {tipo_t}.")
                    continue

                df_temporal = pd.DataFrame(rows_t)
                res_tend = _analisar_tendencia(df_temporal)

                fig_t = go.Figure()
                for idx_c, col in enumerate(cols_t):
                    if col not in df_plot.columns: continue
                    pw  = _extrair_pot(col)
                    cor = cores_t[idx_c % len(cores_t)]
                    df_t = df_plot[['DATA',col]].dropna().sort_values('DATA')
                    if len(df_t) < 2: continue

                    if agrup_code:
                        # Agrupado: barras de média + erro
